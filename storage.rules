rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Only authenticated users can upload or download audio secrets
    match /audio/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // General fallback for future assets
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
