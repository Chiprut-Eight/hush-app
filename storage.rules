rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Audio files: authenticated users can UPLOAD, but reads are blocked
    // (access is via signed URLs generated by Cloud Functions)
    match /audio/{allPaths=**} {
      allow write: if request.auth != null;
      allow read: if false;
    }
    
    // General fallback: block everything by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
