rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Base rule: Allow any authenticated user to interact with the allowed collections.
    // This is required because the HUSH app architecture currently relies on client-side 
    // fan-out writes.
    
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /secrets/{secretId} {
      allow read, write: if request.auth != null;
      
      match /unlockAttempts/{attemptId} {
        allow read, write: if request.auth != null;
      }
      
      match /comments/{commentId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /reports/{reportId} {
      allow read, write: if request.auth != null;
    }
    
    match /appeals/{appealId} {
      allow read, write: if request.auth != null;
    }
  }
}
