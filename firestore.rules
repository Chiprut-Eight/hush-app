rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // USERS — Public read, owner-only write for sensitive fields
    // ========================================
    match /users/{userId} {
      // Any authenticated user can read profiles
      // (Note: field-level read restriction not possible in Firestore;
      //  email/savedSecretIds remain readable. Privacy for these fields
      //  would require moving them to a subcollection in a future phase.)
      allow read: if request.auth != null;
      
      // Only the owner can write their own profile
      // Exception: followerIds may be updated by others (follow system fan-out)
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        // Allow other users to ONLY modify followerIds (for follow fan-out)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerIds']))
      );
      
      match /notifications/{notifId} {
        // Only the owner can read/write their notifications
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // ========================================
    // SECRETS — Metadata readable, content PROTECTED
    // ========================================
    match /secrets/{secretId} {
      // Any authenticated user can read secret metadata
      allow read: if request.auth != null;
      
      // Creation: any authenticated user
      allow create: if request.auth != null;
      
      // Updates: allow interaction fields only (likes, dislikes, views, etc.)
      // Full content/admin changes go through Cloud Functions
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'likes', 'dislikes', 'views', 'viewedBy',
          'saveCount', 'commentCount', 'reportCount',
          'unlockedBy', 'isHidden'
        ]);
      
      // Only creator can delete
      allow delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
      
      // PROTECTED CONTENT — Only accessible via Cloud Functions (Admin SDK)
      match /content/{contentId} {
        allow read: if false;
        allow write: if false;
      }
      
      // Unlock attempts — read by anyone, write only via Cloud Functions
      match /unlockAttempts/{attemptId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
      
      // Comments — CRUD with ownership checks
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }
    }
    
    // ========================================
    // REPORTS & APPEALS — Create only, read via admin CF
    // ========================================
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if false;
      allow update, delete: if false;
    }
    
    match /appeals/{appealId} {
      allow create: if request.auth != null;
      allow read: if false;
      allow update, delete: if false;
    }
  }
}
